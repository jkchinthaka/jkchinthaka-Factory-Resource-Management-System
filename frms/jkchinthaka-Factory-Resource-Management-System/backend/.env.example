# Backend environment variables
# Copy this to .env for local development; set these as env vars on Render for production

NODE_ENV=development

# JWT
JWT_SECRET=change-this-to-a-long-random-string

# Database (SQL Server)
DB_HOST=localhost
DB_PORT=1433
DB_USER=nelna_user
DB_PASSWORD=Nelna@123
DB_NAME=NELNA_APP
DB_ENCRYPT=true
DB_TRUST_CERT=true

# Server
BACKEND_PORT=5000

# CORS — set to your Vercel URL in production, e.g. https://fupms.vercel.app
FRONTEND_URL=http://localhost
